<Window x:Class="POE_PART_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POE_PART_2"
        mc:Ignorable="d"
        Title="Cybersercutiy Awareness Bot" Height="450" Width="800">

    <Grid>
        <!-- Welcome Screen -->
        <Grid x:Name="WelcomeGrid">
         
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">


                <TextBlock Text="Cybersecurity Awareness Bot "
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="DodgerBlue"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Image Source="/logo.jpg"
                       Width="300"
                       Height="200"
                       Margin="10"/>

                <Button Content="Start"
                        Width="150"
                        Height="40" 
                        FontSize="16"
                        FontWeight="Bold"
                        Background="DodgerBlue"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Start_Click"/>
            </StackPanel>
        </Grid>
        <!-- Username Grid -->
        <Grid x:Name="NameGrid"
      Visibility="Collapsed"
      Background="#F0F4F8">

            <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <!-- Decorative background for the form -->
                <Border Background="White"
                CornerRadius="12"
                Padding="30,25"
                Margin="10">
                    <StackPanel>

                        <!-- Title -->
                        <TextBlock Text="Enter your name"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#2C3E50"
                           Margin="10,0,10,15"
                           HorizontalAlignment="Center"/>

                        <!-- Name input with styling -->
                        <Border CornerRadius="6"
                        Background="#F7FAFC"
                        BorderBrush="#CBD5E0"
                        BorderThickness="1"
                        Width="250"
                        Height="45"
                        Margin="10">
                            <TextBox x:Name="NameTextBox"
                             Width="Auto"
                             Height="Auto"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="10,8"
                             FontSize="14"
                             Foreground="#2D3748"
                             CaretBrush="#4299E1"/>
                        </Border>

                        <!-- Error message -->
                        <TextBlock x:Name="ErrorText"
                           Foreground="Red"
                           Margin="5,8,5,5"
                           TextAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>

                        <!-- Submit button -->
                        <Button Content="Submit"
                        Width="150"
                        Height="40" 
                        FontSize="16"
                        FontWeight="Bold"
                        Background="DodgerBlue"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Submit_Click"
                        Cursor="Hand"
                        Margin="10,5,10,0"/>

                    </StackPanel>
                </Border>

            </StackPanel>

        </Grid>


        <!-- Chat Grid -->
    <Grid x:Name="ChatGrid"
      Visibility="Collapsed"
      Background="#F5F7FA">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Subtle border effect for the entire chat area -->
        <Border Grid.Row="0"
            Grid.RowSpan="2"
            Background="White"
            CornerRadius="8"
            Margin="5"
            Opacity="0.05"/>

        <ScrollViewer Grid.Row="0"
                  VerticalScrollBarVisibility="Auto"
                  Margin="0,0,0,10"
                  HorizontalAlignment="Center"
                  Width="780">
            <Border CornerRadius="6"
                Background="White"
                BorderBrush="#E0E4E8"
                BorderThickness="1">
                <TextBox x:Name="ChatListBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="14"
                     Background="White"
                     BorderThickness="0"
                     Padding="10"
                     Foreground="#2C3E50"/>
            </Border>
        </ScrollViewer>

        <StackPanel Orientation="Horizontal"
                Grid.Row="1"
                Margin="10">

            <Border CornerRadius="4"
                Background="White"
                BorderBrush="#D1D8E0"
                BorderThickness="1"
                Width="650"
                Height="35"
                Margin="5">
                <TextBox x:Name="MessageTextBox"
                     Width="Auto"
                     Height="Auto"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="8,8"
                     Foreground="#2C3E50"
                     CaretBrush="#3498DB"/>
            </Border>

            <Button x:Name="Send"
                Content="Send"
                Width="100"
                Height="35"  
                FontWeight="Bold"
                Background="DodgerBlue"
                Foreground="White"
                BorderThickness="0"
                Click="Send_Click"
                Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>

    </Grid>

    </Grid>
   </Window>
